<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.buildenough.marketboard.member.mapper.MemberMapper">
    <insert id="insertMember" parameterType="com.buildenough.marketboard.member.dto.MemberJoinDto">
        INSERT INTO members (
            login_id,
            password,
            name,
            email
        ) VALUES (
            #{loginId},
            #{password},
            #{name},
            #{email}
        )
    </insert>
</mapper>