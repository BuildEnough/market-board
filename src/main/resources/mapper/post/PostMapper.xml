<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.buildenough.marketboard.post.mapper.PostMapper">

    <insert id="insertPost" parameterType="com.buildenough.marketboard.post.dto.PostWriteDto">
        INSERT INTO posts (
            member_id,
            title,
            content
        ) VALUES (
            #{memberId},
            #{title},
            #{content}
        )
    </insert>

</mapper>